<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RedPrince.Resources.Styles.AppStyles">

    <Style x:Key="RedPrimaryButton" TargetType="Button">
        <Setter Property="HeightRequest" Value="50" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#D32F2F, Dark=#EF5350}" />
        <Setter Property="TextColor" Value="White" />
    </Style>

    <Style x:Key="RedSecondaryButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light=#424242, Dark=#BDBDBD}" />
    </Style>

    <Style x:Key="HomeButton" TargetType="Button">
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=White, Dark=#1E1E1E}" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light=#333333, Dark=White}" />
        <Setter Property="BorderColor" Value="{AppThemeBinding Light=#D32F2F, Dark=#EF5350}" />
        <Setter Property="BorderWidth" Value="2" />
    </Style>

    
    <Style x:Key="RedInputBorder" TargetType="Border">
        <Setter Property="StrokeThickness" Value="2" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Stroke" Value="{AppThemeBinding Light=#D32F2F, Dark=#EF5350}" />
        <Setter Property="StrokeShape" Value="RoundRectangle 10,10,10,10" />
    </Style>

    <Style x:Key="RedInputEntry" TargetType="Entry">
        <Setter Property="Margin" Value="10,5" />
        <Setter Property="ClearButtonVisibility" Value="WhileEditing" />
    </Style>

</ResourceDictionary>