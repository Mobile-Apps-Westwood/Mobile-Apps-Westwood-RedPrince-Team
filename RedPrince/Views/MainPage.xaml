<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RedPrince.Views.MainPage"
             Title="{Binding Title}">


	<VerticalStackLayout Spacing="15" Margin="20" VerticalOptions="Center">

		<Label Text="Sign In"
			   FontSize="32"
			   FontAttributes="Bold"
			   HorizontalOptions="Center"
			   Margin="0,0,0,30" />

		<Frame CornerRadius="10" Padding="0" HasShadow="False" BorderColor="LightGray">
			<Entry Placeholder="Username"
				   Text="{Binding Username}"
				   Margin="10,5"
				   ClearButtonVisibility="WhileEditing" />
		</Frame>

		<Frame CornerRadius="10" Padding="0" HasShadow="False" BorderColor="LightGray">
			<Entry Placeholder="Password"
				   Text="{Binding Password}"
				   IsPassword="True"
				   Margin="10,5"
				   ClearButtonVisibility="WhileEditing" />
		</Frame>

		<Button Text="Login"
				Command="{Binding HomeClickedCommand}"
				HeightRequest="50"
				CornerRadius="10"
				Margin="0,20,0,0"
				FontSize="18"
				FontAttributes="Bold" />

		<Grid Margin="0, 10, 0, 0" ColumnSpacing="10">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="*" />
				<ColumnDefinition Width="*" />
			</Grid.ColumnDefinitions>

			<Button Grid.Column="0"
					Text="{Binding Hint}"
					Command="{Binding HintClickedCommand}"
					BackgroundColor="Transparent"
					TextColor="Gray" />

			<Button Grid.Column="1"
					Text="{Binding Create}"
					Command="{Binding CreateClickedCommand}"
					BackgroundColor="Transparent"
					TextColor="Gray" />
		</Grid>

	</VerticalStackLayout>
    
</ContentPage>