<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RedPrince.Views.HomePage"
             Title="{Binding Title}">


    <VerticalStackLayout Spacing="20" Padding="30" VerticalOptions="Center">
        <Label 
            Text="RedPrince Casino"
            FontSize="32"
            FontAttributes="Bold"
            HorizontalOptions="Center"
            Margin="0,0,0,40" />

        <Button Text="{Binding GamesButton}" 
                FontSize="24"
                HeightRequest="60"
                CornerRadius="8"
                Command="{Binding GamesButtonClickedCommand}"/>

        <Button Text="{Binding LeaderboardButton}" 
                FontSize="24"
                HeightRequest="60"
                CornerRadius="8"
                Command="{Binding LeaderBoardsButtonClickedCommand}"/>

        <Button Text="{Binding StoreButton}" 
                FontSize="24"
                HeightRequest="60"
                CornerRadius="8"
                Command="{Binding StoreButtonClickedCommand}"/>

        <Button Text="{Binding SettingsButton}" 
                FontSize="24"
                HeightRequest="60"
                CornerRadius="8"
                Command="{Binding SettingsButtonClickedCommand}"/>

    </VerticalStackLayout>


</ContentPage>