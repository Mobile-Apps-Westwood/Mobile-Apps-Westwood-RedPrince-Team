<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RedPrince.Views.StorePage"
             Title="{Binding Title}">
    
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">
            
            <!-- Current Balance Section -->
            <Border 
                Padding="20"
                StrokeThickness="2"
                Stroke="{AppThemeBinding Light=#D32F2F, Dark=#EF5350}"
                StrokeShape="RoundRectangle 12,12,12,12"
                BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}">
                <VerticalStackLayout Spacing="8">
                    <Label 
                        Text="{Binding CurrentBalanceLabel}"
                        FontSize="14"
                        FontAttributes="Bold"
                        TextColor="{AppThemeBinding Light=#333333, Dark=White}" />
                    <HorizontalStackLayout Spacing="8" HorizontalOptions="Center">
                        <Label 
                            Text="{Binding UserBalance}"
                            FontSize="32"
                            FontAttributes="Bold"
                            TextColor="{AppThemeBinding Light=#D32F2F, Dark=#EF5350}" />
                        <Label 
                            Text="{Binding CoinsLabel}"
                            FontSize="18"
                            VerticalTextAlignment="End"
                            TextColor="{AppThemeBinding Light=#666666, Dark=#BDBDBD}" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>
            
            <!-- Redemption Title -->
            <Label 
                Text="Redeem Your Coins"
                FontSize="16"
                FontAttributes="Bold"
                TextColor="{AppThemeBinding Light=#333333, Dark=White}"
                Margin="0,10,0,0" />

            <!-- 100 Coins Button -->
            <VerticalStackLayout Spacing="6">
                <Button 
                    Text="{Binding Redeem100Label}"
                    Command="{Binding Redeem100CoinsCommand}"
                    IsEnabled="{Binding Is100Enabled}"
                    Style="{StaticResource HomeButton}"
                    FontSize="16" />
                <Label 
                    Text="{Binding Button100Status}"
                    FontSize="12"
                    TextColor="{AppThemeBinding Light=#666666, Dark=#BDBDBD}"
                    HorizontalOptions="Center" />
                <Label 
                    Text="Every 5 seconds"
                    FontSize="11"
                    TextColor="{AppThemeBinding Light=#999999, Dark=#757575}"
                    HorizontalOptions="Center" />
            </VerticalStackLayout>

            <!-- 1k Coins Button -->
            <VerticalStackLayout Spacing="6">
                <Button 
                    Text="{Binding Redeem1kLabel}"
                    Command="{Binding Redeem1kCoinsCommand}"
                    IsEnabled="{Binding Is1kEnabled}"
                    Style="{StaticResource HomeButton}"
                    FontSize="16" />
                <Label 
                    Text="{Binding Button1kStatus}"
                    FontSize="12"
                    TextColor="{AppThemeBinding Light=#666666, Dark=#BDBDBD}"
                    HorizontalOptions="Center" />
                <Label 
                    Text="Every 30 seconds"
                    FontSize="11"
                    TextColor="{AppThemeBinding Light=#999999, Dark=#757575}"
                    HorizontalOptions="Center" />
            </VerticalStackLayout>
            
            <!-- 5k Coins Button -->
            <VerticalStackLayout Spacing="6">
                <Button 
                    Text="{Binding Redeem5kLabel}"
                    Command="{Binding Redeem5kCoinsCommand}"
                    IsEnabled="{Binding Is5kEnabled}"
                    Style="{StaticResource HomeButton}"
                    FontSize="16" />
                <Label 
                    Text="{Binding Button5kStatus}"
                    FontSize="12"
                    TextColor="{AppThemeBinding Light=#666666, Dark=#BDBDBD}"
                    HorizontalOptions="Center" />
                <Label 
                    Text="Every 1 minute"
                    FontSize="11"
                    TextColor="{AppThemeBinding Light=#999999, Dark=#757575}"
                    HorizontalOptions="Center" />
            </VerticalStackLayout>

            <!-- 10k Coins Button -->
            <VerticalStackLayout Spacing="6" Margin="0,0,0,20">
                <Button 
                    Text="{Binding Redeem10kLabel}"
                    Command="{Binding Redeem10kCoinsCommand}"
                    IsEnabled="{Binding Is10kEnabled}"
                    Style="{StaticResource HomeButton}"
                    FontSize="16" />
                <Label 
                    Text="{Binding Button10kStatus}"
                    FontSize="12"
                    TextColor="{AppThemeBinding Light=#666666, Dark=#BDBDBD}"
                    HorizontalOptions="Center" />
                <Label 
                    Text="Every 5 minutes"
                    FontSize="11"
                    TextColor="{AppThemeBinding Light=#999999, Dark=#757575}"
                    HorizontalOptions="Center" />
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
