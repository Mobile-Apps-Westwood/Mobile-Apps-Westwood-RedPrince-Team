<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RedPrince.Views.StorePage"
             Title="{Binding Title}">

    <VerticalStackLayout Padding="20" Spacing="15">

        <VerticalStackLayout Spacing="5" Padding="15" BackgroundColor="#F0F0F0">
            <Label 
                Text="{Binding CurrentBalanceLabel}"
                FontSize="14"
                FontAttributes="Bold"
                TextColor="#333333" />
            <HorizontalStackLayout Spacing="5" HorizontalOptions="Center">
                <Label 
                    Text="{Binding UserBalance}"
                    FontSize="28"
                    FontAttributes="Bold"
                    TextColor="#2196F3" />
                <Label 
                    Text="{Binding CoinsLabel}"
                    FontSize="18"
                    VerticalTextAlignment="End"
                    TextColor="#666666" />
            </HorizontalStackLayout>
        </VerticalStackLayout>
        
        <Label 
            Text="Redeem Your Coins"
            FontSize="16"
            FontAttributes="Bold"
            TextColor="#333333"
            Margin="0,10,0,0" />

        <VerticalStackLayout Spacing="5">
            <Button 
                Text="{Binding Redeem100Label}"
                Command="{Binding Redeem100CoinsCommand}"
                IsEnabled="{Binding Is100Enabled}"
                Padding="15"
                CornerRadius="8"
                FontSize="16"
                FontAttributes="Bold"
                BackgroundColor="#4CAF50"
                TextColor="White" />
            <Label 
                Text="{Binding Button100Status}"
                FontSize="12"
                TextColor="#666666"
                HorizontalOptions="Center" />
            <Label 
                Text="Every 5 seconds"
                FontSize="11"
                TextColor="#999999"
                HorizontalOptions="Center" />
        </VerticalStackLayout>

        <VerticalStackLayout Spacing="5">
            <Button 
                Text="{Binding Redeem1kLabel}"
                Command="{Binding Redeem1kCoinsCommand}"
                IsEnabled="{Binding Is1kEnabled}"
                Padding="15"
                CornerRadius="8"
                FontSize="16"
                FontAttributes="Bold"
                BackgroundColor="#2196F3"
                TextColor="White" />
            <Label 
                Text="{Binding Button1kStatus}"
                FontSize="12"
                TextColor="#666666"
                HorizontalOptions="Center" />
            <Label 
                Text="Every 30 seconds"
                FontSize="11"
                TextColor="#999999"
                HorizontalOptions="Center" />
        </VerticalStackLayout>
        
        <VerticalStackLayout Spacing="5">
            <Button 
                Text="{Binding Redeem5kLabel}"
                Command="{Binding Redeem5kCoinsCommand}"
                IsEnabled="{Binding Is5kEnabled}"
                Padding="15"
                CornerRadius="8"
                FontSize="16"
                FontAttributes="Bold"
                BackgroundColor="#FF9800"
                TextColor="White" />
            <Label 
                Text="{Binding Button5kStatus}"
                FontSize="12"
                TextColor="#666666"
                HorizontalOptions="Center" />
            <Label 
                Text="Every 1 minute"
                FontSize="11"
                TextColor="#999999"
                HorizontalOptions="Center" />
        </VerticalStackLayout>

        <VerticalStackLayout Spacing="5">
            <Button 
                Text="{Binding Redeem10kLabel}"
                Command="{Binding Redeem10kCoinsCommand}"
                IsEnabled="{Binding Is10kEnabled}"
                Padding="15"
                CornerRadius="8"
                FontSize="16"
                FontAttributes="Bold"
                BackgroundColor="#9C27B0"
                TextColor="White" />
            <Label 
                Text="{Binding Button10kStatus}"
                FontSize="12"
                TextColor="#666666"
                HorizontalOptions="Center" />
            <Label 
                Text="Every 5 minutes"
                FontSize="11"
                TextColor="#999999"
                HorizontalOptions="Center" />
        </VerticalStackLayout>

    </VerticalStackLayout>
</ContentPage>