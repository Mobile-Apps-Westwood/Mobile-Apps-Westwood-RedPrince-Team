<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RedPrince.Views.SettingsChangePassPage"
             Title="{Binding Title}">

    <ScrollView>
        <VerticalStackLayout Margin="20" Spacing="16">

            <Border Style="{StaticResource RedInputBorder}">
                <Entry Placeholder="Username" Style="{StaticResource RedInputEntry}" Text="{Binding Username}" />
            </Border>

            <Border Style="{StaticResource RedInputBorder}">
                <Entry Placeholder="Current Password" IsPassword="True" Style="{StaticResource RedInputEntry}" Text="{Binding CurrentPassword}" />
            </Border>

            <Border Style="{StaticResource RedInputBorder}">
                <Entry Placeholder="New Password" IsPassword="True" Style="{StaticResource RedInputEntry}" Text="{Binding NewPassword}" />
            </Border>

            <Border Style="{StaticResource RedInputBorder}">
                <Entry Placeholder="Confirm New Password" IsPassword="True" Style="{StaticResource RedInputEntry}" Text="{Binding ConfirmNewPassword}" />
            </Border>

            <Button Text="Submit" Style="{StaticResource RedPrimaryButton}" Command="{Binding SubmitChangePassCommand}" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
