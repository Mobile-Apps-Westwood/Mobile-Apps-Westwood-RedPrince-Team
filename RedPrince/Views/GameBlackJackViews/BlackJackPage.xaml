<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RedPrince.Views.GameBlackJackViews.BlackJackPage"
             Title="{Binding Title}">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <!-- Dealer Section -->
            <StackLayout>
                <Label Text="Dealer" FontSize="18" FontAttributes="Bold"/>
                <CollectionView ItemsSource="{Binding DealerCards}" SelectionMode="None">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Horizontal" ItemSpacing="10"/>
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Frame BorderColor="Black" CornerRadius="8" Padding="10" HasShadow="True">
                                <VerticalStackLayout Spacing="5" WidthRequest="60" HeightRequest="90">
                                    <Label Text="{Binding RankDisplay}" FontSize="16" FontAttributes="Bold" HorizontalTextAlignment="Center"/>
                                    <Label Text="{Binding SuitSymbol}" FontSize="20" HorizontalTextAlignment="Center" TextColor="Black"/>
                                </VerticalStackLayout>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
                <Label Text="{Binding DealerScore, StringFormat='Score: {0}'}" FontSize="14"/>
            </StackLayout>

            <!-- Game Status -->
            <BoxView Color="#E0E0E0" HeightRequest="1"/>

            <Label Text="{Binding StatusMessage}" FontSize="14" TextColor="Gray"/>
            <Label Text="{Binding ResultMessage}" FontSize="16" FontAttributes="Bold" IsVisible="{Binding ResultVisible}"/>

            <!-- Player Section -->
            <StackLayout>
                <Label Text="Player" FontSize="18" FontAttributes="Bold"/>
                <CollectionView ItemsSource="{Binding PlayerCards}" SelectionMode="None">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Horizontal" ItemSpacing="10"/>
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Frame BorderColor="Black" CornerRadius="8" Padding="10" HasShadow="True">
                                <VerticalStackLayout Spacing="5" WidthRequest="60" HeightRequest="90">
                                    <Label Text="{Binding RankDisplay}" FontSize="16" FontAttributes="Bold" HorizontalTextAlignment="Center"/>
                                    <Label Text="{Binding SuitSymbol}" FontSize="20" HorizontalTextAlignment="Center" TextColor="Black"/>
                                </VerticalStackLayout>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
                <Label Text="{Binding PlayerScore, StringFormat='Score: {0}'}" FontSize="14"/>
            </StackLayout>

            <!-- Betting Section -->
            <StackLayout IsVisible="{Binding IsBettingPhase}" Spacing="10">
                <Label Text="{Binding PlayerBalance, StringFormat='Balance: ${0}'}" FontSize="14" FontAttributes="Bold"/>
                <Label Text="{Binding CurrentBet, StringFormat='Current Bet: ${0}'}" FontSize="14"/>

                <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                    <Button Text="$25" Command="{Binding AddChipCommand}" CommandParameter="{x:Int32 25}" Padding="10,5"/>
                    <Button Text="$50" Command="{Binding AddChipCommand}" CommandParameter="{x:Int32 50}" Padding="10,5"/>
                    <Button Text="$100" Command="{Binding AddChipCommand}" CommandParameter="{x:Int32 100}" Padding="10,5"/>
                </HorizontalStackLayout>

                <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                    <Button Text="Clear Bet" Command="{Binding ClearBetCommand}" Padding="10,5"/>
                    <Button Text="Deal" Command="{Binding DealCommand}" Padding="10,5"/>
                </HorizontalStackLayout>
            </StackLayout>

            <!-- Game Controls -->
            <StackLayout IsVisible="{Binding IsPlayerTurn}" Spacing="10">
                <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                    <Button Text="Hit" Command="{Binding HitCommand}" Padding="10,5"/>
                    <Button Text="Stand" Command="{Binding StandCommand}" Padding="10,5"/>
                    <Button Text="Double Down" Command="{Binding DoubleDownCommand}" Padding="10,5"/>
                </HorizontalStackLayout>
            </StackLayout>

            <!-- New Game Button -->
            <Button Text="New Game" Command="{Binding NewGameCommand}" HorizontalOptions="Fill" Margin="0,10,0,0"/>

            <!-- Stats -->
            <StackLayout>
                <Label Text="Statistics" FontSize="16" FontAttributes="Bold"/>
                <HorizontalStackLayout Spacing="20" HorizontalOptions="Center">
                    <VerticalStackLayout HorizontalOptions="Center">
                        <Label Text="Wins" FontSize="12" HorizontalTextAlignment="Center"/>
                        <Label Text="{Binding Wins}" FontSize="16" FontAttributes="Bold" HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                    <VerticalStackLayout HorizontalOptions="Center">
                        <Label Text="Losses" FontSize="12" HorizontalTextAlignment="Center"/>
                        <Label Text="{Binding Losses}" FontSize="16" FontAttributes="Bold" HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                    <VerticalStackLayout HorizontalOptions="Center">
                        <Label Text="Pushes" FontSize="12" HorizontalTextAlignment="Center"/>
                        <Label Text="{Binding Pushes}" FontSize="16" FontAttributes="Bold" HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                </HorizontalStackLayout>
            </StackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
