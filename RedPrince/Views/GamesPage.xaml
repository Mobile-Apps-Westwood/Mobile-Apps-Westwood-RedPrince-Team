<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RedPrince.Views.GamesPage"
             Title="{Binding Title}">
    <VerticalStackLayout>
        <Label 
            Text="Welcome to .NET MAUI!"
            VerticalOptions="Center" 
            HorizontalOptions="Center" />

        <Button 
            Text="{Binding BlackJackPage}" 
            FontSize="24"
            HeightRequest="60"
            CornerRadius="8"
            Command="{Binding BlackJackPageClickedCommand}"/>
        
    </VerticalStackLayout>
    
</ContentPage>