<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RedPrince.Views.SettingsPage"
             Title="{Binding Title}">

    <ContentPage.Resources>
        <Style TargetType="Button">
            <Setter Property="BackgroundColor" Value="#50C878" />
            <Setter Property="TextColor" Value="Black" />
            <Setter Property="HeightRequest" Value="50"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Margin" Value="3"/>
        </Style>
    </ContentPage.Resources>

    <VerticalStackLayout>
        
        <Button Text ="{Binding ChangeUserPass}"
                Command = "{Binding ChangeUserPassClickedCommand}" />

        <HorizontalStackLayout  HorizontalOptions="Start">

            <Button Text ="{Binding ToggleSound}"
                    Command = "{Binding ToggleSoundCommand}"
                    BackgroundColor ="transparent"/>

            <Switch IsToggled="{Binding IsOn}" 
                    ThumbColor="Blue" 
                    OnColor="Green"
                    HorizontalOptions="Center"/>

        </HorizontalStackLayout>
    </VerticalStackLayout>
</ContentPage>