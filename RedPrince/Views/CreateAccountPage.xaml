<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RedPrince.Views.CreateAccountPage"
             Title="{Binding Title}">
    <VerticalStackLayout Spacing="15" Margin="20" VerticalOptions="Center">
        <Label Text="Create Account"
               FontSize="32"
               FontAttributes="Bold"
               HorizontalOptions="Center"
               Margin="0,0,0,30" />

        <Frame CornerRadius="10" Padding="0" HasShadow="False" BorderColor="LightGray">
            <Entry Placeholder="Username"
                   Text="{Binding Username}"
                   Margin="10,5"
                   ClearButtonVisibility="WhileEditing" />
        </Frame>

        <Frame CornerRadius="10" Padding="0" HasShadow="False" BorderColor="LightGray">
            <Entry Placeholder="Password"
                   Text="{Binding Password}"
                   IsPassword="True"
                   Margin="10,5"
                   ClearButtonVisibility="WhileEditing" />
        </Frame>

        <Frame CornerRadius="10" Padding="0" HasShadow="False" BorderColor="LightGray">
            <Entry Placeholder="Password Hint"
                   Text="{Binding HintEntry}"
                   Margin="10,5"
                   ClearButtonVisibility="WhileEditing" />
        </Frame>

        <Button Text="Create Account"
                Command="{Binding CreateCommand}"
                HeightRequest="50"
                CornerRadius="10"
                Margin="0,20,0,0"
                FontSize="18"
                FontAttributes="Bold" />
    </VerticalStackLayout>
</ContentPage>